{
    "manifest_version": 2,
    "name": "Claude Enter Key Modes",
    "version": "1.0",
    "description": "Choose how Enter behaves on claude.ai",
    "icons": {
      "16": "icons/claude-ai-icon-16.png",
      "32": "icons/claude-ai-icon-32.png",
      "48": "icons/claude-ai-icon-48.png",
      "96": "icons/claude-ai-icon-96.png"
    },
    "permissions": ["storage"],
    "content_scripts": [
      {
        "matches": ["*://claude.ai/*", "*://*.claude.ai/*"],
        "js": ["content.js"],
        "run_at": "document_start",
        "all_frames": true
      }
    ],
    "browser_action": {
      "default_popup": "popup.html",
      "default_title": "Claude Enter Key Modes",
      "default_icon": {
        "16": "icons/claude-ai-icon-16.png",
        "32": "icons/claude-ai-icon-32.png",
        "48": "icons/claude-ai-icon-48.png",
        "96": "icons/claude-ai-icon-96.png"
      }
    },
    "browser_specific_settings": {
      "gecko": {
        "id": "claude-enter-modes@yourname.example"
      }
    }
  }